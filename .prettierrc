{
    "tabWidth": 4,
    "printWidth": 80,
    "useTabs": true,
    "semi": true,
    "singleQuote": true,
    "bracketSpacing": true,
    "singleAttributePerLine": true,
    "bracketSameLine": false,
    "trailingComma": "es5",
    "objectWrap": "preserve",
    "proseWrap": "preserve",
    "endOfLine": "lf",
    "plugins": [
        "prettier-plugin-embed",
        "prettier-plugin-multiline-arrays"
    ],
    "multilineArraysWrapThreshold": 2
}
