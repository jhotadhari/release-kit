{
  "name": "@jhotadhari/release-kit",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.5",
  "description": "Generic release pipeline for libraries and apps — bumps versions, manages changelogs, publishes to npm and GitHub",
  "bin": "./bin/release-kit.js",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "bin"
  ],
  "scripts": {
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "format": "prettier . --write",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "commander": "^15.0.0",
    "keep-a-changelog": "^3.0.5",
    "picocolors": "^1.1.1",
    "semver": "^7.8.5",
    "simple-git": "^3.36.0",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.7",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.22.0",
    "@types/node": "^26.1.0",
    "@types/semver": "^7",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "prettier-plugin-embed": "^0.5.1",
    "prettier-plugin-multiline-arrays": "^4.1.10",
    "typescript": "^5.2.2"
  },
  "packageManager": "yarn@3.6.1"
}
